# ================================
# 1. INSTALAR E CARREGAR PACOTES
# ================================

pacotes <- c("dplyr", "skimr", "janitor")

for (pkg in pacotes) {
  if (!require(pkg, character.only = TRUE)) {
    install.packages(pkg)
    library(pkg, character.only = TRUE)
  }
}

# ================================
#  2. VISÃO GERAL DO BANCO
# ================================

# Dimensão (linhas e colunas)
dim(dados)

# Estrutura das variáveis
str(dados)

# Nomes das variáveis
names(dados)

# ================================
#  3. PADRONIZAR NOMES (opcional, mas recomendado)
# ================================

dados <- janitor::clean_names(dados)

# ================================
#  4. RESUMO GERAL AUTOMÁTICO
# ================================

skimr::skim(dados)

# ================================
#  5. FREQUÊNCIA DAS VARIÁVEIS CATEGÓRICAS
# ================================

# Função para frequência
freq <- function(var) {
  dados %>%
    count({{var}}) %>%
    mutate(percentual = round(100 * n / sum(n), 2))
}

# Exemplos (ajuste conforme suas variáveis reais)

freq(ant_pre_na)      # pré-natal
freq(cs_raca)         # raça
freq(cs_escol_n)      # escolaridade
freq(evolucao)        # evolução
freq(classi_fin)      # classificação

# ================================
