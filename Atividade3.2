# ================================
#  7. DADOS FALTANTES
# ================================

# Quantidade de NA por variável
colSums(is.na(dados))

# Percentual de NA
na_percent <- colSums(is.na(dados)) / nrow(dados) * 100
round(na_percent, 2)

# ================================
# 8. IDENTIFICAR VARIÁVEIS CODIFICADAS
